{
  "name": "media-tools",
  "private": true,
  "packageManager": "yarn@4.14.1",
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build-command-descriptions": "yarn workspace @media-tools/server build-command-descriptions",
    "build-version": "node scripts/build-version.cjs",
    "build": "rimraf build/ && esbuild --format=cjs --minify --bundle --platform=node --external:./xhr-sync-worker.js \"--external:chromium-bidi/*\" --outfile=build/media-tools.cjs packages/server/src/cli.ts",
    "copy-assets": "rimraf dist/assets && mkdir 'dist/assets' && npx cpx2 'assets/**/*' dist/assets/",
    "e2e:ui": "playwright test --ui",
    "e2e": "playwright test",
    "format": "biome check --write --unsafe",
    "generate-external-api-schemas": "yarn workspace @media-tools/server generate-external-api-schemas",
    "generate-internal-api-schemas:watch": "yarn workspace @media-tools/server generate-internal-api-schemas:watch",
    "generate-internal-api-schemas": "yarn workspace @media-tools/server generate-internal-api-schemas",
    "install-playwright-browser": "yarn dlx playwright install chromium",
    "lint": "biome check && eslint .",
    "media": "yarn workspace @media-tools/server media",
    "preapi-dev-server": "yarn build-version && yarn build-command-descriptions",
    "preapi-server": "yarn build-version && yarn build-command-descriptions",
    "prebuild": "yarn build-version && yarn build-command-descriptions",
    "preserver": "node scripts/copy-assets-to-worktree.cjs && yarn build-version && yarn build-command-descriptions",
    "screenshots": "yarn workspace @media-tools/server screenshots",
    "sea": "rimraf dist/ && yarn build && node --experimental-sea-config sea-config.json && mkdir dist && node -e \"require('fs').copyFileSync(process.execPath, 'dist/media-tools.exe')\" && npx postject 'dist/media-tools.exe' NODE_SEA_BLOB 'build/sea-prep.blob' --sentinel-fuse NODE_SEA_FUSE_fce680ab2cc467b6e072b8b5df1996b2 && yarn copy-assets",
    "seed-anidb-fixtures": "yarn workspace @media-tools/server seed-anidb-fixtures",
    "start-server": "yarn workspace @media-tools/server start-server",
    "start": "yarn workspace @media-tools/server start",
    "test": "vitest",
    "typecheck": "concurrently \"tsc --noEmit\" \"yarn workspaces foreach -Ap run typecheck\""
  },
  "type": "module",
  "dependencies": {
    "concurrently": "^9.2.1",
    "fast-sort": "^3.4.1",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.59.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.6.2",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "@yarnpkg/sdks": "^3.2.3",
    "cpx2": "^8.0.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  },
  "resolutions": {
    "mal-scraper@^2.13.2": "patch:mal-scraper@npm%3A2.13.2#./.yarn/patches/mal-scraper-npm-2.13.2-36efb47931.patch"
  }
}
