{
  "name": "media-file-naming",
  "packageManager": "yarn@4.9.0",
  "version": "1.0.0",
  "scripts": {
    "api-server": "tsx --env-file ./.env src/api-server.ts",
    "build": "rimraf build/ && esbuild --format=cjs --minify --bundle --platform=node --external:./xhr-sync-worker.js --outfile=build/media-tools.cjs src/cli.ts",
    "cli-server": "tsx --env-file ./.env src/cli-server.ts",
    "copy-assets": "rimraf dist/assets && mkdir 'dist/assets' && npx cpx2 'assets/**/*' dist/assets/",
    "generate-schemas": "tsx --env-file ./.env src/generateSchemas.ts",
    "media": "tsx --env-file ./.env src/cli.ts",
    "sea": "rimraf dist/ && yarn build && node --experimental-sea-config sea-config.json && mkdir dist && node -e \"require('fs').copyFileSync(process.execPath, 'dist/media-tools.exe')\" && npx postject 'dist/media-tools.exe' NODE_SEA_BLOB 'build/sea-prep.blob' --sentinel-fuse NODE_SEA_FUSE_fce680ab2cc467b6e072b8b5df1996b2 && yarn copy-assets",
    "server": "tsx --env-file ./.env src/start-servers.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "@hono/zod-openapi": "^1.3.0",
    "@lydell/node-pty": "1.1.0",
    "@scalar/hono-api-reference": "^0.10.13",
    "@scalar/openapi-to-markdown": "^0.5.12",
    "@xterm/xterm": "^5.5.0",
    "ansi-colors": "^4.1.3",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "fast-sort": "^3.4.1",
    "fast-xml-parser": "^4.4.1",
    "he": "^1.2.0",
    "hono": "^4.12.16",
    "inquirer": "^10.1.8",
    "jsdom": "^26.1.0",
    "mal-scraper": "^2.13.1",
    "memfs": "^4.14.0",
    "openapi-fetch": "^0.11.1",
    "puppeteer": "^23.1.0",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "yargs": "^17.7.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@total-typescript/ts-reset": "^0.5.1",
    "@types/cli-progress": "^3.11.0",
    "@types/ffmpeg-static": "^3.0.3",
    "@types/he": "^1.2.3",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.4.1",
    "@types/yargs": "^17.0.33",
    "@vitest/ui": "2.1.3",
    "@yarnpkg/sdks": "^3.2.0",
    "cpx2": "^8.0.0",
    "esbuild": "^0.25.5",
    "openapi-typescript": "^7.3.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.17.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "resolutions": {
    "mal-scraper@^2.13.1": "patch:mal-scraper@npm%3A2.13.1#./.yarn/patches/mal-scraper-npm-2.13.1-8a68a57707.patch"
  }
}
