{
  "name": "media-file-naming",
  "packageManager": "yarn@4.9.0",
  "version": "1.0.0",
  "scripts": {
    "api-dev-server": "tsx watch --env-file ./.env src/api-server.ts",
    "api-server": "tsx --env-file ./.env src/api-server.ts",
    "build": "rimraf build/ && esbuild --format=cjs --minify --bundle --platform=node --external:./xhr-sync-worker.js \"--external:chromium-bidi/*\" --outfile=build/media-tools.cjs src/cli.ts",
    "cli-server": "tsx --env-file ./.env src/cli-server.ts",
    "copy-assets": "rimraf dist/assets && mkdir 'dist/assets' && npx cpx2 'assets/**/*' dist/assets/",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "generate-schemas": "tsx --env-file ./.env src/generateSchemas.ts",
    "install-playwright-browser": "yarn dlx playwright install chromium",
    "media": "tsx --env-file ./.env src/cli.ts",
    "sea": "rimraf dist/ && yarn build && node --experimental-sea-config sea-config.json && mkdir dist && node -e \"require('fs').copyFileSync(process.execPath, 'dist/media-tools.exe')\" && npx postject 'dist/media-tools.exe' NODE_SEA_BLOB 'build/sea-prep.blob' --sentinel-fuse NODE_SEA_FUSE_fce680ab2cc467b6e072b8b5df1996b2 && yarn copy-assets",
    "server": "tsx --env-file ./.env src/start-servers.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "@hono/zod-openapi": "^1.3.0",
    "@lydell/node-pty": "1.1.0",
    "@scalar/hono-api-reference": "^0.10.14",
    "@scalar/openapi-to-markdown": "^0.5.14",
    "@types/js-yaml": "^4.0.9",
    "@xterm/xterm": "^6.0.0",
    "ansi-colors": "^4.1.3",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "fast-sort": "^3.4.1",
    "fast-xml-parser": "^5.7.3",
    "he": "^1.2.0",
    "hono": "^4.12.18",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.1.1",
    "mal-scraper": "^2.13.1",
    "memfs": "^4.57.2",
    "openapi-fetch": "^0.17.0",
    "playwright": "^1.59.1",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "trash": "^10.1.1",
    "tree-kill": "^1.2.2",
    "yargs": "^18.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/cli-progress": "^3.11.6",
    "@types/ffmpeg-static": "^5.1.0",
    "@types/he": "^1.2.3",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/yargs": "^17.0.35",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "@yarnpkg/sdks": "^3.2.3",
    "cpx2": "^8.0.2",
    "esbuild": "^0.28.0",
    "openapi-typescript": "^7.13.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "resolutions": {
    "mal-scraper@^2.13.1": "patch:mal-scraper@npm%3A2.13.1#./.yarn/patches/mal-scraper-npm-2.13.1-8a68a57707.patch"
  }
}
