CLI_SERVER_PORT=8081
PORT=8080
REMOTE_SERVER_URL=https://my-server.local
TVDB_API_KEY=00000000-0000-0000-0000-000000000000
# TMDB v4 read-access token (NOT the v3 api_key). Generate one at
# https://www.themoviedb.org/settings/api after creating a v4 application.
# Sent as `Authorization: Bearer <token>` to api.themoviedb.org/3.
TMDB_API_KEY=replace-with-your-tmdb-v4-bearer-token
