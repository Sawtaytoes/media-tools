{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@media-tools/web/*": ["packages/web/*"]
    }
  },
  "include": ["e2e", "scripts", "*.json", "*.ts"],
  "exclude": [".claude/workspaces", "packages"]
}
