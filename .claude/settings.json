{
  "permissions": {
    "allow": [
      "Bash(awk '{print $5}')",
      "Bash(cat *)",
      "Bash(cp *)",
      "Bash(curl *)",
      "Bash(dig *)",
      "Bash(disown)",
      "Bash(du *)",
      "Bash(echo *)",
      "Bash(ffprobe *)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(gh auth *)",
      "Bash(gh pr *)",
      "Bash(gh run *)",
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(ifconfig *)",
      "Bash(ip *)",
      "Bash(ls *)",
      "Bash(lsof *)",
      "Bash(nc *)",
      "Bash(netstat *)",
      "Bash(npm test *)",
      "Bash(npm view *)",
      "Bash(npx *)",
      "Bash(nslookup *)",
      "Bash(ping *)",
      "Bash(pwd *)",
      "Bash(python3 -c * 2>/dev/null)",
      "Bash(python3 -c *)",
      "Bash(rsync *)",
      "Bash(ss *)",
      "Bash(stat *)",
      "Bash(tail *)",
      "Bash(telnet *)",
      "Bash(traceroute *)",
      "Bash(tree *)",
      "Bash(wc *)",
      "Bash(wget *)",
      "Bash(whereis *)",
      "Bash(which *)",
      "Bash(xargs -r kill)",
      "Bash(yarn *)",
      "Bash(yarn typecheck * | tail *)",
      "PowerShell($proc | netstat -ano *)",
      "PowerShell(cat *)",
      "PowerShell(Copy-Item *)",
      "PowerShell(cp *)",
      "PowerShell(Get-*)",
      "PowerShell(Get-ChildItem * | ForEach-Object *)",
      "PowerShell(Get-ChildItem * | Select-Object *)",
      "PowerShell(gh --version 2>&1)",
      "PowerShell(git *)",
      "PowerShell(ls *)",
      "PowerShell(Measure-*)",
      "PowerShell(netstat -ano | findstr *)",
      "PowerShell(npx *)",
      "PowerShell(pwd *)",
      "PowerShell(Select-*)",
      "PowerShell(Select-String * | Select-Object *)",
      "PowerShell(until Select-String *)",
      "PowerShell(Where-*)",
      "PowerShell(yarn *)",
      "Read(**)",
      "Skill(update-config:*)",
      "Skill(update-config)"
    ],
    "deny": [
      "Bash(Get-ChildItem *)",
      "Bash(npx *)",
      "PowerShell(npx *)"
    ],
    "ask": [
      "Bash(yarn dlx *)",
      "PowerShell(yarn dlx *)"
    ]
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.worktree_path // empty' | { read -r wt; if [ -n \"$wt\" ] && [ -d '.claude' ]; then cp -r '.claude' \"$wt/.claude\" 2>/dev/null || true; fi; }",
            "shell": "bash",
            "statusMessage": "Copying Claude settings to worktree..."
          }
        ]
      }
    ]
  }
}
