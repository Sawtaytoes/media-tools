{
  "name": "@media-tools/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Hono API server + CLI for batch media file operations.",
  "scripts": {
    "build-command-descriptions": "tsx scripts/build-command-descriptions.ts",
    "generate-external-api-schemas": "tsx --env-file-if-exists ./.env packages/server/src/generateExternalApiSchemas.ts",
    "generate-internal-api-schemas:watch": "tsx watch --env-file-if-exists ./.env packages/server/src/generateInternalApiSchemas.ts",
    "generate-internal-api-schemas": "tsx --env-file-if-exists ./.env packages/server/src/generateInternalApiSchemas.ts",
    "media": "tsx --env-file-if-exists ./.env packages/server/src/cli.ts",
    "screenshots": "tsx scripts/screenshots.ts",
    "seed-anidb-fixtures": "tsx scripts/seedAnidbFixtures.ts",
    "start-server": "tsx --env-file-if-exists=../../.env src/server.ts",
    "start": "tsx --env-file-if-exists=../../.env src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@hono/zod-openapi": "^1.4.0",
    "@scalar/hono-api-reference": "^0.10.14",
    "@scalar/openapi-to-markdown": "^0.5.14",
    "ansi-colors": "^4.1.3",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "fast-xml-parser": "^5.7.3",
    "hono": "^4.12.18",
    "jsdom": "^29.1.1",
    "mal-scraper": "patch:mal-scraper@npm%3A2.13.2#~/.yarn/patches/mal-scraper-npm-2.13.2-36efb47931.patch",
    "memfs": "^4.57.2",
    "openapi-fetch": "^0.17.0",
    "rxjs": "^7.8.2",
    "trash": "^10.1.1",
    "tree-kill": "^1.2.2",
    "yargs": "^18.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/ffmpeg-static": "^5.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.1",
    "@types/yargs": "^17.0.35",
    "js-yaml": "^4.1.1",
    "msw": "^2.14.5",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
