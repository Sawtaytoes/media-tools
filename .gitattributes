# Normalize line endings for all text files. LF in both the index and the
# working tree, regardless of each contributor's core.autocrlf setting.
# Suppresses the "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

/.yarn/**            linguist-vendored
/.yarn/releases/*    binary
/.yarn/plugins/**/*  binary
/.pnp.*              binary linguist-generated
