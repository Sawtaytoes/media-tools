.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

apps.generated/
assets/
build/
dist/
node_modules/

# Generated by scripts/build-version.cjs at prebuild/prestart; served
# at runtime by src/api/routes/versionRoutes.ts.
public/api/version.json

# Generated by scripts/build-command-descriptions.ts at prebuild/prestart;
# loaded by public/builder/index.html as the field-tooltip content source.
public/builder/js/command-descriptions.js

.cache
.env
installed_packages.txt

# Playwright Test artifacts
playwright-report/
test-results/

# Vitest browser-mode failure screenshots
**/__screenshots__/
**/.vitest-attachments/

# Claude Code per-machine permission overrides
.claude/settings.local.json

# Sub-agent worktrees created by Agent isolation:"worktree" (each is a
# full repo checkout — never meant to be committed to the parent).
.claude/worktrees/

# Generated by scripts/generate-schemas at prebuild from the running Hono
# /openapi.json endpoint; consumed by packages/web's openapi-fetch client.
# Not committed — Docker builds and CI generate it on the fly.
packages/web/src/api/schema.generated.ts

*.log

# Local copy of Biome JSON schema (avoids IDE untrusted-URL warning)
biome-schema.downloaded.json
